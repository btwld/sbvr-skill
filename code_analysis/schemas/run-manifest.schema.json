{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/RunManifest",
  "definitions": {
    "RunManifest": {
      "type": "object",
      "properties": {
        "target": {
          "type": "string"
        },
        "startedAt": {
          "type": "string"
        },
        "finishedAt": {
          "type": "string"
        },
        "overallStatus": {
          "$ref": "#/definitions/StepStatus"
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/StepResult"
          }
        }
      },
      "required": [
        "target",
        "startedAt",
        "finishedAt",
        "overallStatus",
        "steps"
      ],
      "additionalProperties": false
    },
    "StepStatus": {
      "type": "string",
      "enum": [
        "passed",
        "findings",
        "failed",
        "skipped",
        "unsupported"
      ]
    },
    "StepResult": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/StepStatus"
        },
        "durationMs": {
          "type": "number"
        },
        "exitCode": {
          "type": "number"
        },
        "reason": {
          "type": "string"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "status",
        "durationMs",
        "artifacts"
      ],
      "additionalProperties": false
    }
  }
}
