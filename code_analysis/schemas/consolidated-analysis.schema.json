{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/ConsolidatedReviewArtifact",
  "definitions": {
    "ConsolidatedReviewArtifact": {
      "anyOf": [
        {
          "$ref": "#/definitions/CoverageMap"
        },
        {
          "$ref": "#/definitions/FlowCatalog"
        },
        {
          "$ref": "#/definitions/HotspotCatalog"
        },
        {
          "$ref": "#/definitions/FindingCatalog"
        },
        {
          "$ref": "#/definitions/ConsolidatedOverview"
        }
      ]
    },
    "CoverageMap": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "v1"
        },
        "kind": {
          "type": "string",
          "const": "coverage-map"
        },
        "datasetId": {
          "type": "string"
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/CoverageMapEntry"
          }
        },
        "ownershipConflicts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unownedHotspots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "schemaVersion",
        "kind",
        "datasetId",
        "entries",
        "ownershipConflicts",
        "unownedHotspots"
      ],
      "additionalProperties": false
    },
    "CoverageMapEntry": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        },
        "ownerAgentId": {
          "type": "string"
        },
        "ownerDomain": {
          "type": "string"
        },
        "supportingAgentIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "supportingDomains": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "path",
        "ownerAgentId",
        "ownerDomain",
        "supportingAgentIds",
        "supportingDomains"
      ],
      "additionalProperties": false
    },
    "FlowCatalog": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "v1"
        },
        "kind": {
          "type": "string",
          "const": "flow-catalog"
        },
        "datasetId": {
          "type": "string"
        },
        "flows": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ConsolidatedFlow"
          }
        }
      },
      "required": [
        "schemaVersion",
        "kind",
        "datasetId",
        "flows"
      ],
      "additionalProperties": false
    },
    "ConsolidatedFlow": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "entryPoints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "services": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stateOwners": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sensitiveData": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "externalBoundaries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "riskNotes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "agentIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "domains": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "agentIds",
        "domains",
        "entryPoints",
        "externalBoundaries",
        "id",
        "name",
        "riskNotes",
        "sensitiveData",
        "services",
        "stateOwners"
      ],
      "additionalProperties": false
    },
    "HotspotCatalog": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "v1"
        },
        "kind": {
          "type": "string",
          "const": "hotspot-catalog"
        },
        "datasetId": {
          "type": "string"
        },
        "hotspots": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ConsolidatedHotspot"
          }
        }
      },
      "required": [
        "schemaVersion",
        "kind",
        "datasetId",
        "hotspots"
      ],
      "additionalProperties": false
    },
    "ConsolidatedHotspot": {
      "type": "object",
      "properties": {
        "file": {
          "type": "string"
        },
        "score": {
          "type": "number"
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "agentIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "domains": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sourceMetrics": {
          "type": "object",
          "properties": {
            "complexity": {
              "type": "number"
            },
            "duplication": {
              "type": "number"
            },
            "revisions": {
              "type": "number"
            },
            "findings": {
              "type": "number"
            }
          },
          "required": [
            "complexity",
            "duplication",
            "revisions",
            "findings"
          ],
          "additionalProperties": false
        },
        "evidenceRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "file",
        "score",
        "reasons",
        "agentIds",
        "domains",
        "sourceMetrics",
        "evidenceRefs"
      ],
      "additionalProperties": false
    },
    "FindingCatalog": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "v1"
        },
        "kind": {
          "type": "string",
          "const": "finding-catalog"
        },
        "datasetId": {
          "type": "string"
        },
        "findingClusters": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ConsolidatedFindingCluster"
          }
        }
      },
      "required": [
        "schemaVersion",
        "kind",
        "datasetId",
        "findingClusters"
      ],
      "additionalProperties": false
    },
    "ConsolidatedFindingCluster": {
      "type": "object",
      "properties": {
        "clusterId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "category": {
          "$ref": "#/definitions/ReviewClusterCategory"
        },
        "severity": {
          "$ref": "#/definitions/ReviewRiskLevel"
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidenceRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommendation": {
          "type": "string"
        },
        "agentIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "domains": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "agentIds",
        "category",
        "clusterId",
        "domains",
        "evidenceRefs",
        "files",
        "recommendation",
        "severity",
        "title"
      ],
      "additionalProperties": false
    },
    "ReviewClusterCategory": {
      "type": "string",
      "enum": [
        "security",
        "maintainability",
        "duplication",
        "change-risk",
        "policy",
        "dead-code",
        "architecture"
      ]
    },
    "ReviewRiskLevel": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "medium",
        "low"
      ]
    },
    "ConsolidatedOverview": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "v1"
        },
        "kind": {
          "type": "string",
          "const": "overview"
        },
        "datasetId": {
          "type": "string"
        },
        "counts": {
          "type": "object",
          "properties": {
            "agentCount": {
              "type": "number"
            },
            "distinctHotspotFiles": {
              "type": "number"
            },
            "distinctFindingClusters": {
              "type": "number"
            },
            "crossDomainFiles": {
              "type": "number"
            },
            "sourceCoveragePercent": {
              "type": "number"
            },
            "reportReadyDatasetCount": {
              "type": "number"
            },
            "unownedHotspotCount": {
              "type": "number"
            }
          },
          "required": [
            "agentCount",
            "distinctHotspotFiles",
            "distinctFindingClusters",
            "crossDomainFiles",
            "sourceCoveragePercent",
            "reportReadyDatasetCount",
            "unownedHotspotCount"
          ],
          "additionalProperties": false
        },
        "topPriorities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "priority": {
                "$ref": "#/definitions/RecommendationPriority"
              },
              "action": {
                "type": "string"
              },
              "domains": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "affectedFiles": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "recommendationIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "priority",
              "action",
              "domains",
              "affectedFiles",
              "recommendationIds"
            ],
            "additionalProperties": false
          }
        },
        "reportInputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "schemaVersion",
        "kind",
        "datasetId",
        "counts",
        "topPriorities",
        "reportInputs"
      ],
      "additionalProperties": false
    },
    "RecommendationPriority": {
      "type": "string",
      "enum": [
        "p0",
        "p1",
        "p2"
      ]
    }
  }
}
